# Secrets
.env

# Docker persistent data (generated at runtime)
*/config/
*/data/
*/cache/
*/metadata/
*/letsencrypt/
*/generated/
*/blobs/

# Certbot runtime data (certs, accounts, ACME challenges)
certbot/conf/
certbot/www/

# Generated by the dnsmasq-render container; machine-specific (contains LAN IP)
dnsmasq/conf.d/local.conf

# Generated by the helpsite-render container from helpsite/*.tmpl
helpsite-rendered/
