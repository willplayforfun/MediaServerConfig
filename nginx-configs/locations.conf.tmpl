
# Rendered into ./nginx-configs-rendered/locations.conf by the nginx-render
# container (envsubst). Included inside the port-80 and port-443 server blocks.
# Only ${PLEX_HTTPS_PORT} is substituted here; all other $variables are nginx
# runtime variables. Edit this template, not the rendered output.

# Resolve upstreams at request time via Docker's embedded DNS. Putting the
# upstream host in a variable forces per-request resolution, so nginx starts
# regardless of which optional services are enabled; a disabled or down service
# returns 502 rather than preventing nginx from starting.
resolver 127.0.0.11 valid=30s ipv6=off;

# ── Help site ─────────────────────────────────────────────────────────────────
location = / {
    return 301 /help/;
}
location /help {
    return 301 /help/;
}
location /help/ {
    alias /usr/share/nginx/html/;
    index index.html;
}

# ── Jellyfin ──────────────────────────────────────────────────────────────────
location /jellyfin {
    return 301 $scheme://$host/jellyfin/;
}
location /jellyfin/ {
    set $jellyfin_upstream jellyfin;
    proxy_pass http://$jellyfin_upstream:8096;

    proxy_pass_header Authorization;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Protocol $scheme;
    proxy_set_header X-Forwarded-Host  $http_host;

    # WebSocket support (required for Jellyfin)
    proxy_http_version 1.1;
    proxy_set_header Upgrade    $http_upgrade;
    proxy_set_header Connection "upgrade";

    # Disable buffering to prevent streaming issues
    proxy_buffering off;
}

# ── Plex ────────────────────────────────────────────────────────────────────────
# Plex can't be proxied under a subpath, so /plex is just a convenience launcher
# that bounces to its dedicated HTTPS port (see the Plex server block in nginx.conf).
location = /plex {
    return 302 https://$host:${PLEX_HTTPS_PORT}/web;
}

# ── Audiobookshelf ────────────────────────────────────────────────────────────
location /audiobookshelf {
    set $audiobookshelf_upstream audiobookshelf;
    proxy_pass http://$audiobookshelf_upstream:80;

    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_set_header Upgrade           $http_upgrade;
    proxy_set_header Connection        "upgrade";
}

# ── Navidrome ─────────────────────────────────────────────────────────────────
location /music {
    return 301 $scheme://$host/music/;
}
location /music/ {
    set $navidrome_upstream navidrome;
    proxy_pass http://$navidrome_upstream:4533;

    proxy_pass_header Authorization;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Protocol $scheme;
    proxy_set_header X-Forwarded-Host  $http_host;

    proxy_buffering off;
}

# ── Filebrowser ───────────────────────────────────────────────────────────────
location /files {
    return 301 $scheme://$host/files/;
}
location /files/ {
    set $filebrowser_upstream filebrowser;
    proxy_pass http://$filebrowser_upstream:80;

    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_set_header Upgrade           $http_upgrade;
    proxy_set_header Connection        "upgrade";
